# Daraja environment
# Use `sandbox` for testing and `production` for go-live
DARAJA_ENV=production
DARAJA_MOCK=false

# Safaricom Daraja credentials
DARAJA_CONSUMER_KEY=replace_with_live_consumer_key
DARAJA_CONSUMER_SECRET=replace_with_live_consumer_secret
DARAJA_SHORTCODE=replace_with_live_shortcode
DARAJA_PASSKEY=replace_with_live_lipa_na_mpesa_passkey

# Public HTTPS callback URL
DARAJA_CALLBACK_URL=https://replace-with-live-domain.com/api/stk_callback

# Optional
DARAJA_ACCOUNT_REFERENCE=MkopoExtra
DARAJA_TRANSACTION_DESC=Loan processing fee
PORT=3000

# Network tuning (optional)
DARAJA_HTTP_TIMEOUT_MS=60000
DARAJA_HTTP_RETRIES=1
