
# MkopoExtra Daraja .env example
# Fill in all values below for production. Sandbox values are provided for testing.

PORT=3000
NODE_ENV=development
DARAJA_MOCK_STK=false

# Sandbox base URL. For production, use https://api.safaricom.co.ke
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke

# Daraja app credentials (get from Safaricom Daraja portal)
DARAJA_CONSUMER_KEY=h2YO3jDev2fquQNVYaEtgC3sS9RNuJlm1o3k2DBQUcGFKug9
DARAJA_CONSUMER_SECRET=ouU4cAHAaRvl6I0S7h9uJI4hLz39Mi4HupZdiBXhgtd8zMow6NYXrVfIRoJnqZhH

# STK credentials
# Sandbox shared test values:
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97ddf9f1b5f4b6b17f81e8f8f52ce8f86f4e9f0f5f6d
# For production, replace with your own shortcode and passkey from Daraja portal

# Public HTTPS callback endpoint (must be accessible by Safaricom)
DARAJA_CALLBACK_URL=https://webhook.site/0aead27f-150d-4d00-817d-ae07310105ec
# For production, use your own public HTTPS endpoint

# Transaction type: CustomerPayBillOnline or CustomerBuyGoodsOnline
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline
DARAJA_ACCOUNT_REFERENCE=MkopoExtra
DARAJA_TRANSACTION_DESC=Loan processing fee
CI=your_customer_identifier
CID=your_customer_id
